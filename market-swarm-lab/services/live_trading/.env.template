# Live Orderflow Alert Service Configuration Template
# Copy to .env and fill in actual values

# ============================================
# Rithmic Feed Configuration
# ============================================
RITHMIC_USERNAME=your_rithmic_username
RITHMIC_PASSWORD=your_rithmic_password
RITHMIC_ACCOUNT_ID=your_account_id
RITHMIC_ENVIRONMENT=live  # or 'paper' for test
RITHMIC_SOCKET_PORT=8000

# ============================================
# Bookmap Configuration
# ============================================
BOOKMAP_API_KEY=your_bookmap_api_key
BOOKMAP_HOST=localhost
BOOKMAP_PORT=9000
BOOKMAP_SYMBOLS=ES,NQ,GC,CL
BOOKMAP_DEPTH_LEVELS=20

# ============================================
# Alert Configuration
# ============================================
ALERT_MIN_ORDER_SIZE=100
ALERT_MIN_ABSORPTION_SIZE=500
ALERT_MIN_FOLLOW_THROUGH=300
ALERT_REGIME_THRESHOLD_USD=10000
ALERT_WHATSAPP_ENABLED=true
ALERT_EMAIL_ENABLED=false

# ============================================
# WhatsApp Configuration (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
ALERT_RECIPIENT_PHONE=+1987654321

# ============================================
# Regime Detection
# ============================================
REGIME_MA_SHORT=5
REGIME_MA_LONG=20
REGIME_ATR_PERIOD=14
REGIME_VOLATILITY_THRESHOLD=0.02

# ============================================
# Absorption Detection
# ============================================
ABSORPTION_TIME_WINDOW_MS=2000
ABSORPTION_DELTA_MIN_RATIO=0.5
ABSORPTION_VOLUME_MIN_PCT=0.3

# ============================================
# Follow-Through Confirmation
# ============================================
FOLLOWTHROUGH_TIME_WINDOW_MS=5000
FOLLOWTHROUGH_MIN_CONFIRMATION_COUNT=2
FOLLOWTHROUGH_MIN_VOLUME_RATIO=0.4

# ============================================
# Service Configuration
# ============================================
SERVICE_LOG_LEVEL=INFO
SERVICE_TICK_INTERVAL_MS=100
SERVICE_HISTORY_DEPTH=1000
SERVICE_REDIS_URL=redis://localhost:6379/0
SERVICE_DEBUG_MODE=false
SERVICE_MOCK_FEED_MODE=false

# ============================================
# Performance & Monitoring
# ============================================
MONITOR_ENABLED=true
MONITOR_METRICS_PORT=8888
MONITOR_ALERT_QUEUE_MAX_SIZE=1000
MONITOR_ERROR_LOG_PATH=./logs/errors.log
