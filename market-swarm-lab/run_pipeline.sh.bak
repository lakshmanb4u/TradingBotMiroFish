#!/bin/bash
set -e
cd "$(dirname "$0")"
echo "=== 1. Validate ==="
python scripts/validate_orderflow_export.py \
  --input state/orderflow/raw/2026-05-02/es_synthetic_test_fixture_20260502.csv \
  --source-type synthetic_test_fixture \
  --output state/orderflow/audit/validation_report.json

echo "=== 2. Normalize ==="
python scripts/normalize_bookmap_export.py \
  --input state/orderflow/raw/2026-05-02/es_synthetic_test_fixture_20260502.csv \
  --source-type synthetic_test_fixture \
  --output state/orderflow/2026-05-02/es_synthetic_test_fixture.parquet

echo "=== 3. Inspect ==="
python scripts/inspect_orderflow_parquet.py \
  --input state/orderflow/2026-05-02/es_synthetic_test_fixture.parquet \
  --output state/orderflow/audit/parquet_summary.json

echo "=== 4. Replay smoke test ==="
python scripts/replay_smoke_test.py \
  --input state/orderflow/2026-05-02/es_synthetic_test_fixture.parquet \
  --output state/orderflow/audit/replay_safety_report.json

echo "=== Done ==="
